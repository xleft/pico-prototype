</div><!-- /main-area -->

<script>
// ══════════════════════════════════
// 页面配置
// ══════════════════════════════════
const SCREENS = {
  's1': { name: '语音房主界面', sub: '基础场景 · 点击主播头像或演示按钮触发交互' },
  's2': { name: '频道关系入口', sub: '首页悬浮提示 · 点击右下角悬浮按钮跳转语音房' },
  's3': { name: '心动挑战开启弹窗', sub: '破除萌新身份后触发 · 居中小型弹窗' },
  's4': { name: '心动挑战即将完成', sub: '送出CP礼物后触发 · 引导参与CPDAY' },
  's5': { name: '心动挑战详情页', sub: '活动页风格 · 任务进度与奖励合并展示' },
  's6': { name: '主播信息弹框', sub: '含心动挑战进行中入口按鈕' },
  's7': { name: '主播中心看板', sub: '主播视角 · 心动挑战萌新列表 · 点击条目查看详情' },
  's8': { name: '挑战详情·主播视角', sub: '主播查看特定用户的心动挑战进度' },
  's9': { name: 'CPday 私信提醒', sub: '周四系统代主播发送给用户的提醒私信' },
};

// 备注存储
const NOTES = {};

function switchScreen(id) {
  // 保存当前备注
  const current = document.querySelector('.screen.active');
  if (current) {
    NOTES[current.id] = document.getElementById('notesArea').value;
  }

  // 切换 screen
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');

  // 切换 nav 高亮
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const navEl = document.getElementById('nav-' + id);
  if (navEl) navEl.classList.add('active');

  // 更新页面标签
  const cfg = SCREENS[id];
  if (cfg) document.getElementById('pageLabel').textContent = cfg.name + ' · ' + cfg.sub;

  // 恢复备注
  document.getElementById('notesArea').value = NOTES[id] || '';

  // 重置 s7 弹窗状态
  if (id === 's7') {
    const d = document.getElementById('s7-detail-overlay');
    if (d) d.classList.remove('show');
  }

  // 重置 s1 弹窗状态
  if (id === 's1') {
    document.getElementById('overlay').classList.remove('show');
    document.getElementById('overlay2').classList.remove('show');
    document.getElementById('anchorOverlay').classList.remove('show');
    document.getElementById('detailPage').classList.remove('show');
    document.getElementById('giftAnim').classList.remove('show');
    document.getElementById('giftMsg').classList.remove('show');
    document.getElementById('demoBtn').style.display = 'block';
  }
}

// ══════════════════════════════════
// Screen 1 交互逻辑
// ══════════════════════════════════
function showChallenge() {
  document.getElementById('overlay').classList.add('show');
  document.getElementById('demoBtn').style.display = 'none';
}
function hideChallenge() {
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('demoBtn').style.display = 'block';
}
function handleOverlayClick(e) {
  if (e.target === document.getElementById('overlay')) hideChallenge();
}

function sendGift() {
  document.getElementById('overlay').classList.remove('show');
  const animEl = document.getElementById('giftAnim');
  animEl.classList.add('show');
  setTimeout(() => { document.getElementById('giftMsg').classList.add('show'); }, 300);
  setTimeout(() => {
    animEl.classList.remove('show');
    document.getElementById('overlay2').classList.add('show');
  }, 1400);
}
function hideModal2() {
  document.getElementById('overlay2').classList.remove('show');
  document.getElementById('giftMsg').classList.remove('show');
  document.getElementById('demoBtn').style.display = 'block';
}

function showDetail() {
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('detailPage').classList.add('show');
}
function hideDetail() {
  document.getElementById('detailPage').classList.remove('show');
  document.getElementById('demoBtn').style.display = 'block';
}

function showAnchorCard() {
  document.getElementById('anchorOverlay').classList.add('show');
  document.getElementById('demoBtn').style.display = 'none';
}
function hideAnchorCard() {
  document.getElementById('anchorOverlay').classList.remove('show');
  document.getElementById('demoBtn').style.display = 'block';
}
function handleAnchorOverlayClick(e) {
  if (e.target === document.getElementById('anchorOverlay')) hideAnchorCard();
}
function showDetailFromAnchor() {
  document.getElementById('anchorOverlay').classList.remove('show');
  document.getElementById('detailPage').classList.add('show');
}

// ══════════════════════════════════
// Screen 2 交互逻辑
// ══════════════════════════════════
// ══════════════════════════════════
// Screen 7 交互逻辑
// ══════════════════════════════════
const S7_USERS = {
  user1: {
    name: '小月光儿',
    seed: 'newuser1',
    bg: 'ffd5dc',
    days: 11,
    node1: true,
    node2: false
  },
  user2: {
    name: '天天开心',
    seed: 'newuser2',
    bg: 'c0aede',
    days: 7,
    node1: false,
    node2: false
  },
  user3: {
    name: '海海大世界',
    seed: 'newuser3',
    bg: 'b6e3f4',
    days: 3,
    node1: true,
    node2: true
  }
};

function showS7Detail(userId) {
  const u = S7_USERS[userId];
  if (!u) return;
  document.getElementById('s7-user-avatar').src =
    `https://api.dicebear.com/7.x/avataaars/svg?seed=${u.seed}&backgroundColor=${u.bg}`;
  document.getElementById('s7-user-name').textContent = u.name;
  document.getElementById('s7-days-left').textContent = `❤️ 还剩 ${u.days} 天`;
  const n1 = document.getElementById('s7-node1-status');
  const n2 = document.getElementById('s7-node2-status');
  if (u.node1) {
    n1.textContent = '✓ 已完成';
    n1.style.background = 'rgba(76,217,100,.15)';
    n1.style.color = '#4cd964';
  } else {
    n1.textContent = '待完成';
    n1.style.background = 'rgba(255,107,157,.15)';
    n1.style.color = '#ff9de2';
  }
  if (u.node2) {
    n2.textContent = '✓ 已完成';
    n2.style.background = 'rgba(76,217,100,.15)';
    n2.style.color = '#4cd964';
  } else {
    n2.textContent = '待完成';
    n2.style.background = 'rgba(255,107,157,.15)';
    n2.style.color = '#ff9de2';
  }
  document.getElementById('s7-detail-overlay').classList.add('show');
}

function hideS7Detail(e) {
  if (e && e.target !== document.getElementById('s7-detail-overlay')) return;
  document.getElementById('s7-detail-overlay').classList.remove('show');
}
function hideS7DetailBtn() {
  document.getElementById('s7-detail-overlay').classList.remove('show');
}

// ══════════════════════════════════
// Screen 9 交互逻辑
// ══════════════════════════════════
function showS9Msg() {
  document.getElementById('s9-msg-overlay').classList.add('show');
}
function hideS9Msg(e) {
  if (e && e.target !== document.getElementById('s9-msg-overlay')) return;
  document.getElementById('s9-msg-overlay').classList.remove('show');
}

function goToRoomWithToast() {
  switchScreen('s1');
  // 切换后显示进房提示
  setTimeout(() => {
    const toast = document.createElement('div');
    toast.className = 'room-entry-toast show';
    toast.innerHTML = `
      <button class="toast-close" onclick="this.parentElement.remove()">✕</button>
      <div class="toast-title">💗 心动挑战提醒</div>
      <div class="toast-body">你与 <em>Sx.晚风</em> 的心动挑战还剩 <em>13 天</em>！<br>本周四参与 CPDAY，送出信物礼物即可完成！</div>
      <button class="toast-btn" onclick="showChallenge();this.closest('.room-entry-toast').remove()">查看心动挑战 ›</button>
    `;
    document.getElementById('s1').appendChild(toast);
    setTimeout(() => { if (toast.parentElement) toast.remove(); }, 5000);
  }, 400);
}
</script>
</body>
</html>
