              </div>
            </div>
            <!-- 心动挑战进度卡片 -->
            <div style="background:linear-gradient(135deg,#fff0f6,#ffe4f0);border:1px solid rgba(255,107,157,.25);border-radius:14px;padding:12px 14px;margin-bottom:14px;">
              <div style="font-size:12px;font-weight:700;color:#e8336d;margin-bottom:8px">💗 心动挑战进度</div>
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <div style="text-align:center;">
                  <div style="font-size:11px;color:#999;margin-bottom:4px">结成甜蜜 CP</div>
                  <div style="font-size:12px;font-weight:700;color:#4cd964">✓ 已完成</div>
                </div>
                <div style="color:#e8336d;font-size:18px">❤️</div>
                <div style="text-align:center;">
                  <div style="font-size:11px;color:#999;margin-bottom:4px">参与 CPday</div>
                  <div style="font-size:12px;font-weight:700;color:#ff9de2">待完成</div>
                </div>
              </div>
              <div style="margin-top:8px;text-align:center;color:rgba(0,0,0,.4);font-size:11px">还剩 11 天 · 完成后可获得心动专属沙发</div>
            </div>
            <!-- 跳转按鈕 -->
            <button onclick="switchScreen('s1');hideS9Msg()" style="width:100%;height:42px;background:linear-gradient(135deg,#ff6b9d,#c96bff);border:none;border-radius:21px;color:#fff;font-size:14px;font-weight:700;cursor:pointer;">🎤 进入语音房参与 CPday</button>
          </div>
        </div>
