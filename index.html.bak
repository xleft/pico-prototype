        </div>

        <!-- 其他私信 -->
        <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.05);">
          <div style="width:46px;height:46px;border-radius:50%;overflow:hidden;background:#2a1040;flex-shrink:0;">
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=s3&backgroundColor=d1d4f9" alt="" style="width:100%;height:100%;object-fit:cover;">
          </div>
          <div style="flex:1;min-width:0;">
            <div style="color:#fff;font-size:13px;font-weight:600">Sx.清欢</div>
            <div style="color:rgba(255,255,255,.35);font-size:12px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">今晚开房吗？</div>
          </div>
          <div style="color:rgba(255,255,255,.25);font-size:11px;flex-shrink:0;">昨天</div>
        </div>
      </div>

      <!-- 点击心动挑战条目展开私信内容 -->
      <div class="s9-msg-overlay" id="s9-msg-overlay" onclick="hideS9Msg(event)">
        <div class="s9-msg-card">
          <!-- 顶部标题栏 -->
          <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-bottom:1px solid rgba(0,0,0,.06);">
            <span style="font-size:22px">💗</span>
            <div>
              <div style="font-size:14px;font-weight:700;color:#1a1a1a">Pico 心动提醒</div>
