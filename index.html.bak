        <div class="home-nav-btn">
          <div class="home-nav-btn-icon">🎤</div>
          <div class="home-nav-btn-label">语音房</div>
        </div>
        <div class="home-nav-btn active">
          <div class="home-nav-btn-icon">💬</div>
          <div class="home-nav-btn-label" style="color:#ff9de2">消息</div>
