<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>心动挑战 · 交互原型</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: #0f0f13;
  font-family: -apple-system,'PingFang SC','Helvetica Neue',sans-serif;
  display: flex;
  min-height: 100vh;
  overflow: hidden;
}

/* ══════════════════════════════════
   侧边目录导航
══════════════════════════════════ */
.sidebar {
  width: 240px;
  min-width: 240px;
  background: #16161e;
  border-right: 1px solid rgba(255,255,255,.07);
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow-y: auto;
  z-index: 100;
}
.sidebar-header {
  padding: 20px 16px 14px;
  border-bottom: 1px solid rgba(255,255,255,.07);
}
.sidebar-title {
  font-size: 13px; font-weight: 700;
  color: rgba(255,255,255,.9);
  letter-spacing: .5px;
}
.sidebar-subtitle {
  font-size: 11px; color: rgba(255,255,255,.35);
  margin-top: 3px;
}
.sidebar-section-label {
  font-size: 10px; font-weight: 700;
  color: rgba(255,255,255,.25);
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 14px 16px 6px;
}
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 16px;
  cursor: pointer;
  border-radius: 0;
  transition: background .15s;
  position: relative;
}
.nav-item:hover { background: rgba(255,255,255,.05); }
.nav-item.active {
  background: rgba(255,107,157,.12);
}
.nav-item.active::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px;
  background: linear-gradient(180deg, #ff6b9d, #c96bff);
  border-radius: 0 2px 2px 0;
}
.nav-dot {
  width: 7px; height: 7px; border-radius: 50%;
  flex-shrink: 0;
}
.nav-dot.pink   { background: #ff6b9d; }
.nav-dot.purple { background: #c96bff; }
.nav-dot.blue   { background: #5b9fff; }
.nav-dot.green  { background: #4cd964; }
.nav-dot.orange { background: #ff9500; }
.nav-dot.gray   { background: rgba(255,255,255,.25); }
.nav-item-text { flex: 1; }
.nav-item-name {
  font-size: 13px; color: rgba(255,255,255,.75);
  line-height: 1.3;
}
.nav-item.active .nav-item-name { color: #ff9de2; font-weight: 600; }
.nav-item-sub {
  font-size: 10px; color: rgba(255,255,255,.3);
  margin-top: 1px;
}
.nav-badge {
  font-size: 9px; font-weight: 700;
  padding: 1px 6px; border-radius: 8px;
  background: rgba(255,107,157,.2);
  color: #ff9de2;
}

/* 备注区域 */
.sidebar-notes {
  margin-top: auto;
  border-top: 1px solid rgba(255,255,255,.07);
  padding: 12px 16px;
}
.notes-label {
  font-size: 10px; font-weight: 700;
  color: rgba(255,255,255,.25);
  letter-spacing: 1px;
  margin-bottom: 6px;
}
.notes-textarea {
  width: 100%;
  min-height: 72px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 8px;
  color: rgba(255,255,255,.6);
  font-size: 11px;
  padding: 8px;
  resize: vertical;
  font-family: inherit;
  line-height: 1.5;
  outline: none;
}
.notes-textarea:focus {
  border-color: rgba(255,107,157,.4);
}
.notes-textarea::placeholder { color: rgba(255,255,255,.2); }

/* ══════════════════════════════════
   主内容区
══════════════════════════════════ */
.main-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  overflow: hidden;
  position: relative;
}

/* 页面标签 */
.page-label {
  position: absolute;
  top: 20px; left: 50%;
  transform: translateX(-50%);
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 20px;
  padding: 5px 16px;
  font-size: 12px; color: rgba(255,255,255,.45);
  white-space: nowrap;
  pointer-events: none;
  z-index: 10;
}

/* ══════════════════════════════════
   手机壳
══════════════════════════════════ */
.phone {
  width: 390px;
  height: 844px;
  position: relative;
  overflow: hidden;
  border-radius: 44px;
  box-shadow: 0 0 0 2px #333, 0 0 0 4px #555, 0 20px 60px rgba(0,0,0,.8);
  background: #0a0008;
  flex-shrink: 0;
}

/* ══════════════════════════════════
   页面容器（每个屏幕状态）
══════════════════════════════════ */
.screen {
  position: absolute; inset: 0;
  display: none;
}
.screen.active { display: block; }

/* ══════════════════════════════════
   通用：语音房背景
══════════════════════════════════ */
.bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 50% 30%, rgba(180,20,20,.55) 0%, transparent 70%),
    radial-gradient(ellipse 80% 60% at 30% 60%, rgba(120,10,60,.4) 0%, transparent 70%),
    radial-gradient(ellipse 60% 50% at 70% 70%, rgba(80,0,80,.35) 0%, transparent 70%),
    linear-gradient(180deg, #1a0010 0%, #0d0008 60%, #050005 100%);
  z-index: 0;
}
.wings-glow {
  position: absolute; top: 80px; left: 50%;
  transform: translateX(-50%);
  width: 340px; height: 200px;
  background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(220,60,20,.35) 0%, transparent 70%);
  z-index: 1; pointer-events: none;
}

/* ══════════════════════════════════
   状态栏 / 导航栏（通用）
══════════════════════════════════ */
.status-bar {
  position: absolute; top: 0; left: 0; right: 0; height: 44px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 20px; z-index: 10; color: #fff;
  font-size: 15px; font-weight: 600;
}
.status-bar .time { font-size: 16px; font-weight: 700; }
.status-bar .icons { display: flex; align-items: center; gap: 4px; font-size: 12px; }
.nav-bar {
  position: absolute; top: 44px; left: 0; right: 0; height: 44px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 12px; z-index: 10;
}
.nav-left { display: flex; align-items: center; gap: 6px; }
.nav-back { color: #fff; font-size: 20px; }
.nav-room-info { display: flex; flex-direction: column; }
.nav-room-name { color: #fff; font-size: 13px; font-weight: 600; max-width: 100px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.nav-room-id { color: rgba(255,255,255,.6); font-size: 11px; }
.nav-follow-btn {
  background: linear-gradient(135deg, #ff6b9d, #ff3d7f);
  color: #fff; border: none; border-radius: 14px;
  padding: 4px 14px; font-size: 13px; font-weight: 600; cursor: pointer;
}
.nav-right { display: flex; align-items: center; gap: 8px; }
.nav-icon { color: rgba(255,255,255,.8); font-size: 18px; }
.nav-vip-badge {
  background: rgba(255,215,0,.15); border: 1px solid rgba(255,215,0,.3);
  border-radius: 10px; padding: 2px 8px;
  color: #ffd700; font-size: 11px; font-weight: 600;
}
.nav-online { color: rgba(255,255,255,.5); font-size: 11px; }

/* ══════════════════════════════════
   语音房通用组件
══════════════════════════════════ */
.room-tags {
  position: absolute; top: 92px; left: 12px; right: 12px;
  display: flex; align-items: center; gap: 6px; z-index: 5;
}
.tag-pill {
  background: rgba(255,255,255,.1); border-radius: 10px;
  padding: 3px 8px; color: rgba(255,255,255,.7); font-size: 11px;
  display: flex; align-items: center; gap: 3px;
}
.tag-pill.gold { background: rgba(255,215,0,.15); color: #ffd700; }
.tag-pill.pink { background: rgba(255,107,157,.15); color: #ff9de2; }
.tag-wish {
  margin-left: auto;
  background: rgba(255,107,157,.15); border: 1px solid rgba(255,107,157,.3);
  border-radius: 10px; padding: 3px 8px;
  color: #ff9de2; font-size: 11px;
  display: flex; align-items: center; gap: 3px;
}
.shield-badge {
  position: absolute; top: 92px; right: 12px;
  background: rgba(100,180,255,.15); border: 1px solid rgba(100,180,255,.3);
  border-radius: 10px; padding: 3px 8px;
  color: #80c8ff; font-size: 11px;
}
.mic-area {
  position: absolute; top: 118px; left: 0; right: 0;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  z-index: 5;
}
.host-seat {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  cursor: pointer;
}
.host-avatar-wrap { position: relative; }
.host-crown { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); font-size: 16px; }
.host-avatar {
  width: 72px; height: 72px; border-radius: 50%;
  border: 2px solid rgba(255,150,200,.5);
  overflow: hidden; background: #4a2060;
  box-shadow: 0 0 20px rgba(255,107,157,.4);
}
.host-avatar img { width:100%; height:100%; object-fit:cover; }
.host-label {
  position: absolute; bottom: -8px; left: 50%; transform: translateX(-50%);
  background: linear-gradient(135deg,#ff6b9d,#c96bff);
  color: #fff; font-size: 9px; font-weight: 700;
  padding: 1px 7px; border-radius: 6px; white-space: nowrap;
}
.host-name { color: #fff; font-size: 12px; font-weight: 600; margin-top: 10px; }
.host-hearts { color: rgba(255,150,200,.7); font-size: 10px; }
.guest-label {
  font-size: 10px; color: rgba(255,255,255,.3);
  align-self: flex-start; padding-left: 16px;
  margin-top: 4px;
}
.seats-row {
  display: flex; gap: 12px; justify-content: center;
  width: 100%; padding: 0 12px;
}
.seat { display: flex; flex-direction: column; align-items: center; gap: 2px; }
.seat-avatar {
  width: 52px; height: 52px; border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,.15);
  overflow: hidden; background: #2a1040; position: relative;
}
.seat-avatar img { width:100%; height:100%; object-fit:cover; }
.seat-num {
  position: absolute; bottom: 0; right: 0;
  background: rgba(0,0,0,.6); color: rgba(255,255,255,.7);
  font-size: 9px; padding: 1px 3px; border-radius: 4px 0 0 0;
}
.seat-name { color: rgba(255,255,255,.7); font-size: 10px; max-width: 52px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; text-align: center; }
.seat-hearts { color: rgba(255,150,200,.5); font-size: 9px; }
.empty-seat .seat-avatar {
  background: rgba(255,255,255,.05);
  border: 1.5px dashed rgba(255,255,255,.15);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; color: rgba(255,255,255,.2);
}
.chat-area {
  position: absolute; bottom: 60px; left: 0; right: 0;
  height: 160px; padding: 0 12px;
  display: flex; flex-direction: column; justify-content: flex-end; gap: 4px;
  z-index: 5;
}
.chat-tabs { display: flex; gap: 12px; margin-bottom: 4px; }
.chat-tab { font-size: 13px; font-weight: 600; }
.chat-tab.active { color: #fff; }
.chat-tab.inactive { color: rgba(255,255,255,.35); }
.chat-notice { font-size: 10px; color: rgba(255,255,255,.3); }
.chat-msg { font-size: 12px; color: rgba(255,255,255,.7); line-height: 1.5; }
.chat-msg .sys { color: rgba(100,180,255,.8); font-weight: 600; }
.chat-msg .user { color: #ff9de2; font-weight: 600; }
.chat-msg .anchor { color: #ffd700; font-weight: 600; }
.chat-msg .heart-icon { color: #c96bff; }
.bottom-bar {
  position: absolute; bottom: 0; left: 0; right: 0; height: 60px;
  display: flex; align-items: center; gap: 8px;
  padding: 0 12px; z-index: 10;
  background: linear-gradient(0deg, rgba(0,0,0,.6) 0%, transparent 100%);
}
.input-box {
  flex: 1; height: 34px;
  background: rgba(255,255,255,.1); border-radius: 17px;
  display: flex; align-items: center; padding: 0 14px;
  color: rgba(255,255,255,.35); font-size: 13px;
}
.bottom-icons { display: flex; gap: 6px; }
.bottom-icon {
  width: 34px; height: 34px; border-radius: 50%;
  background: rgba(255,255,255,.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; color: #fff; position: relative; cursor: pointer;
}
.badge-dot {
  position: absolute; top: -2px; right: -2px;
  background: #ff3b30; color: #fff;
  font-size: 8px; font-weight: 700;
  min-width: 14px; height: 14px;
  border-radius: 7px; padding: 0 3px;
  display: flex; align-items: center; justify-content: center;
}
.recharge-btn {
  background: linear-gradient(135deg, #ff6b9d, #ff3d7f);
  color: #fff; border: none; border-radius: 14px;
  padding: 5px 12px; font-size: 12px; font-weight: 700; cursor: pointer;
}
.right-float {
  position: absolute; right: 8px; top: 200px;
  display: flex; flex-direction: column; gap: 8px; z-index: 8;
}
.float-card {
  width: 52px; background: rgba(255,255,255,.1); border-radius: 10px;
  padding: 6px 4px; text-align: center;
}
.float-card-img { font-size: 20px; }
.float-card-label { font-size: 8px; color: rgba(255,255,255,.6); line-height: 1.3; margin-top: 3px; }
.float-card-2 {
  width: 52px; background: rgba(255,215,0,.12);
  border: 1px solid rgba(255,215,0,.25); border-radius: 10px;
  padding: 6px 4px; text-align: center;
}
.float-card-2-text { font-size: 11px; font-weight: 700; color: #ffd700; }
.float-card-2-sub { font-size: 8px; color: rgba(255,215,0,.7); margin-top: 2px; }
.page-indicator {
  position: absolute; bottom: 68px; right: 12px;
  font-size: 10px; color: rgba(255,255,255,.3); z-index: 5;
}

/* ══════════════════════════════════
   心动挑战弹窗（弹窗1）
══════════════════════════════════ */
.overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,.55); z-index: 30;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none;
  transition: opacity .25s;
}
.overlay.show { opacity: 1; pointer-events: all; }
.challenge-modal {
  width: 300px;
  background: linear-gradient(160deg, #2a0a2e 0%, #1a0520 60%, #0f0318 100%);
  border: 1px solid rgba(255,107,157,.3);
  border-radius: 20px;
  padding: 0 0 18px;
  position: relative;
  overflow: hidden;
  transform: scale(.92);
  transition: transform .3s cubic-bezier(.34,1.56,.64,1);
}
.overlay.show .challenge-modal { transform: scale(1); }
.modal-handle {
  width: 36px; height: 4px; border-radius: 2px;
  background: rgba(255,255,255,.2);
  margin: 10px auto 0;
}
.modal-close {
  position: absolute; top: 10px; right: 14px;
  background: none; border: none;
  color: rgba(255,255,255,.4); font-size: 16px; cursor: pointer;
}
.modal-header { padding: 12px 16px 0; text-align: center; }
.modal-title-wrap { display: flex; align-items: center; justify-content: center; gap: 6px; }
.modal-title { color: #fff; font-size: 17px; font-weight: 700; }
.modal-avatars {
  margin: 16px 0 0;
  display: flex; align-items: center; justify-content: center; gap: 0;
}
.modal-avatar-wrap { display: flex; flex-direction: column; align-items: center; gap: 5px; }
.modal-avatar {
  width: 52px; height: 52px; border-radius: 50%;
  border: 2px solid rgba(255,150,200,.5);
  overflow: hidden; background: linear-gradient(135deg,#8b4a6b,#4a2060);
}
.modal-avatar img { width:100%; height:100%; object-fit:cover; }
.modal-avatar-name { color: rgba(255,255,255,.7); font-size: 11px; }
.modal-heart {
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; margin: 0 4px; margin-bottom: 18px;
}
.modal-rewards { margin: 14px 16px 0; display: flex; gap: 8px; }
.reward-card {
  flex: 1; background: rgba(255,255,255,.05);
  border-radius: 12px; padding: 10px 8px;
  display: flex; flex-direction: column; align-items: center; gap: 5px;
  position: relative;
}
.reward-card.primary { border: 1px solid rgba(255,107,157,.3); background: rgba(255,107,157,.07); }
.reward-card.secondary { border: 1px solid rgba(180,100,255,.25); background: rgba(180,100,255,.06); }
.reward-badge {
  position: absolute; top: -8px; left: 50%; transform: translateX(-50%);
  background: linear-gradient(135deg,#ff6b35,#ff3d7f);
  color: #fff; font-size: 9px; font-weight: 700;
  padding: 2px 7px; border-radius: 6px; white-space: nowrap;
}
.reward-icon { font-size: 26px; margin-top: 4px; }
.reward-name { color: #fff; font-size: 12px; font-weight: 700; text-align: center; }
.reward-desc { color: rgba(255,255,255,.45); font-size: 10px; text-align: center; line-height: 1.4; }
.modal-btns { margin: 14px 16px 0; display: flex; gap: 8px; }
.modal-btn-secondary {
  flex: 1; height: 40px;
  background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
  border-radius: 20px; color: rgba(255,255,255,.8); font-size: 13px; font-weight: 600;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
}
.modal-btn-primary {
  flex: 1; height: 40px;
  background: linear-gradient(135deg,#ff6b9d,#c96bff);
  border: none; border-radius: 20px;
  color: #fff; font-size: 13px; font-weight: 700;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
}

/* ══════════════════════════════════
   送礼动画
══════════════════════════════════ */
.gift-anim-overlay {
  position: absolute; inset: 0; z-index: 50;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  pointer-events: none; opacity: 0; transition: opacity .3s;
}
.gift-anim-overlay.show { opacity: 1; pointer-events: auto; }
.gift-fly { font-size: 64px; animation: giftFly 1.2s ease-out forwards; filter: drop-shadow(0 0 20px rgba(255,215,0,.8)); }
@keyframes giftFly {
  0%   { transform: scale(.3) translateY(120px); opacity: 0; }
  30%  { transform: scale(1.3) translateY(-10px); opacity: 1; }
  60%  { transform: scale(1.0) translateY(-30px); opacity: 1; }
  100% { transform: scale(.6) translateY(-80px); opacity: 0; }
}
.gift-burst {
  position: absolute; width: 200px; height: 200px; border-radius: 50%;
  background: radial-gradient(circle, rgba(255,215,0,.35) 0%, rgba(255,107,157,.2) 40%, transparent 70%);
  animation: burstAnim 1.2s ease-out forwards;
}
@keyframes burstAnim {
  0%   { transform: scale(0); opacity: 1; }
  100% { transform: scale(3); opacity: 0; }
}
.gift-msg-bar {
  position: absolute; bottom: 140px; left: 12px; right: 80px;
  background: rgba(255,107,157,.18); border: 1px solid rgba(255,107,157,.35);
  border-radius: 10px; padding: 6px 10px;
  color: #fff; font-size: 12px; z-index: 51;
  display: none; animation: slideUp .4s ease-out;
}
.gift-msg-bar.show { display: block; }
@keyframes slideUp {
  from { transform: translateY(12px); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}
.gift-msg-bar .gm-user { color: #ff9de2; font-weight: 700; }
.gift-msg-bar .gm-gift { color: #ffd700; font-weight: 700; }

/* ══════════════════════════════════
   第二弹窗：心动挑战即将完成
══════════════════════════════════ */
.overlay2 {
  position: absolute; inset: 0; background: rgba(0,0,0,.55);
  z-index: 60; display: none; align-items: center; justify-content: center;
}
.overlay2.show { display: flex; }
.challenge-modal2 {
  width: 300px;
  background: linear-gradient(160deg,#2a0a2e 0%,#1a0520 60%,#0f0318 100%);
  border: 1px solid rgba(255,107,157,.3); border-radius: 20px;
  padding: 0 0 18px; position: relative; overflow: hidden;
  animation: modalPop .35s cubic-bezier(.34,1.56,.64,1) forwards;
}
@keyframes modalPop {
  from { transform: scale(.85); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
.modal2-header-band {
  background: linear-gradient(135deg,#ff6b9d,#c96bff);
  padding: 14px 16px 12px; text-align: center;
}
.modal2-title { color: #fff; font-size: 16px; font-weight: 700; }
.modal2-subtitle { color: rgba(255,255,255,.85); font-size: 12px; margin-top: 4px; line-height: 1.5; }
.modal2-close {
  position: absolute; top: 10px; right: 14px;
  background: rgba(255,255,255,.2); border: none; border-radius: 50%;
  width: 22px; height: 22px; color: #fff; font-size: 12px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
.cpday-features { display: flex; gap: 0; margin: 14px 0 0; }
.cpday-feat {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px;
  padding: 0 6px;
  border-right: 1px solid rgba(255,255,255,.08);
}
.cpday-feat:last-child { border-right: none; }
.cpday-feat-icon { font-size: 22px; }
.cpday-feat-name { color: #fff; font-size: 11px; font-weight: 700; }
.cpday-feat-desc { color: rgba(255,255,255,.45); font-size: 9px; text-align: center; line-height: 1.4; }
.modal2-btn {
  display: block; margin: 14px 16px 0;
  width: calc(100% - 32px); height: 40px;
  background: linear-gradient(135deg,#ff6b9d,#c96bff);
  border: none; border-radius: 20px;
  color: #fff; font-size: 14px; font-weight: 700; cursor: pointer;
}

/* ══════════════════════════════════
   心动挑战详情页
══════════════════════════════════ */
.detail-page {
  position: absolute; inset: 0; z-index: 40;
  background: linear-gradient(180deg,#1a0030 0%,#0d0020 50%,#050010 100%);
  display: none; flex-direction: column; overflow: hidden;
}
.detail-page.show { display: flex; }
.detail-header {
  position: relative; height: 44px;
  display: flex; align-items: center; padding: 0 16px;
  z-index: 5;
}
.detail-back {
  background: none; border: none; color: rgba(255,255,255,.7);
  font-size: 22px; cursor: pointer; padding: 0; line-height: 1;
}
.detail-timer {
  position: absolute; right: 16px;
  background: rgba(255,255,255,.1); border-radius: 12px;
  padding: 4px 10px; color: rgba(255,255,255,.6); font-size: 11px;
}
.detail-hero {
  padding: 8px 16px 16px; text-align: center; position: relative;
}
.detail-hero-stars { display: flex; justify-content: center; gap: 6px; margin-bottom: 8px; }
.detail-star { color: rgba(255,200,100,.5); font-size: 12px; }
.detail-hero-title { color: #fff; font-size: 22px; font-weight: 800; }
.detail-hero-subtitle { color: rgba(255,255,255,.5); font-size: 12px; margin-top: 4px; }
.detail-body { flex: 1; overflow-y: auto; padding-bottom: 20px; }
.detail-cp-section { margin: 0 16px 12px; }
.detail-cp-pair {
  display: flex; align-items: center; justify-content: center; gap: 0;
  margin-bottom: 10px;
}
.detail-cp-avatar-wrap { display: flex; flex-direction: column; align-items: center; gap: 5px; }
.detail-cp-avatar {
  width: 60px; height: 60px; border-radius: 50%;
  border: 2px solid rgba(255,150,200,.4); overflow: hidden;
  background: #2a1040;
}
.detail-cp-avatar img { width:100%; height:100%; object-fit:cover; }
.detail-cp-name { color: rgba(255,255,255,.7); font-size: 11px; }
.detail-cp-heart-wrap {
  width: 44px; display: flex; align-items: center; justify-content: center;
  margin-bottom: 18px;
}
.detail-cp-heart { font-size: 26px; animation: heartbeat 1.5s ease-in-out infinite; }
@keyframes heartbeat {
  0%,100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}
.detail-cp-label {
  text-align: center;
  background: rgba(255,107,157,.12); border: 1px solid rgba(255,107,157,.25);
  border-radius: 20px; padding: 6px 16px;
  color: #ff9de2; font-size: 12px; font-weight: 600;
}
.detail-rewards-section { margin: 0 16px 10px; }
.detail-section-title {
  color: rgba(255,200,100,.7); font-size: 12px; font-weight: 700;
  letter-spacing: 1px; margin-bottom: 10px;
}
.detail-reward-item {
  background: rgba(255,255,255,.04); border-radius: 14px;
  padding: 12px 12px 12px 12px; margin-bottom: 8px;
  display: flex; align-items: center; gap: 10px;
  position: relative; overflow: hidden;
}
.detail-reward-item.primary { border: 1px solid rgba(255,107,157,.2); }
.detail-reward-item.secondary { border: 1px solid rgba(180,100,255,.15); }
.detail-reward-tag {
  position: absolute; top: 0; right: 0;
  font-size: 9px; font-weight: 700;
  padding: 3px 8px; border-radius: 0 14px 0 8px;
}
.tag-core { background: linear-gradient(135deg,#ff6b35,#ff3d7f); color: #fff; }
.tag-hidden { background: rgba(180,100,255,.3); color: #c96bff; }
.detail-reward-icon-wrap { font-size: 28px; flex-shrink: 0; }
.detail-reward-info { flex: 1; min-width: 0; }
.detail-reward-name { color: #fff; font-size: 13px; font-weight: 700; }
.detail-reward-desc { color: rgba(255,255,255,.45); font-size: 11px; margin-top: 2px; line-height: 1.4; }
.progress-step-status {
  font-size: 10px; font-weight: 700;
  padding: 3px 8px; border-radius: 8px; white-space: nowrap;
}
.status-pending { background: rgba(255,107,157,.15); color: #ff9de2; }
.status-done { background: rgba(76,217,100,.15); color: #4cd964; }
.detail-rules-section {
  margin: 6px 16px 0;
  background: rgba(255,255,255,.03); border-radius: 14px;
  padding: 14px; border: 1px solid rgba(255,255,255,.06);
}
.detail-rules-title {
  color: rgba(255,255,255,.4); font-size: 11px; font-weight: 600;
  letter-spacing: 1px; margin-bottom: 8px;
}
.detail-rule-line {
  color: rgba(255,255,255,.35); font-size: 10px;
  line-height: 1.8; padding-left: 10px; position: relative;
}
.detail-rule-line::before {
  content: '·'; position: absolute; left: 0;
  color: rgba(255,107,157,.6);
}

/* ══════════════════════════════════
   主播信息弹框
══════════════════════════════════ */
.anchor-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,.55);
  z-index: 200; display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity .25s ease;
}
.anchor-overlay.show { opacity: 1; pointer-events: all; }
.anchor-card {
  width: 100%; background: #fff; border-radius: 20px 20px 0 0;
  padding-bottom: 24px; position: relative;
  transform: translateY(30px);
  transition: transform .3s cubic-bezier(.34,1.56,.64,1);
}
.anchor-overlay.show .anchor-card { transform: translateY(0); }
.anchor-avatar-float {
  position: absolute; top: -44px; left: 50%; transform: translateX(-50%);
  width: 88px; height: 88px; border-radius: 50%;
  border: 3px solid #fff; overflow: hidden;
  box-shadow: 0 4px 16px rgba(0,0,0,.25); background: #eee;
}
.anchor-avatar-float img { width:100%; height:100%; object-fit:cover; }
.anchor-card-body { padding: 52px 20px 0; }
.anchor-card-report { position: absolute; top: 14px; right: 18px; color: #bbb; font-size: 12px; }
.anchor-name-row { display: flex; align-items: center; justify-content: center; gap: 6px; margin-bottom: 4px; }
.anchor-name { font-size: 17px; font-weight: 700; color: #1a1a1a; }
.anchor-gender { font-size: 14px; }
.anchor-pico-id { text-align: center; font-size: 12px; color: #999; margin-bottom: 10px; }
.anchor-badges { display: flex; justify-content: center; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
.anchor-badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
.badge-purple { background: #f0eaff; color: #7c3aed; }
.badge-gold   { background: #fffbea; color: #b45309; }
.badge-blue   { background: #eaf4ff; color: #1d6fa4; }
.anchor-stats-row { display: flex; gap: 10px; margin-bottom: 10px; }
.anchor-stat-box { flex: 1; background: #f8f8f8; border-radius: 12px; padding: 10px 12px; text-align: center; }
.anchor-stat-label { font-size: 11px; color: #999; margin-bottom: 6px; }
.anchor-stat-icon { font-size: 28px; margin-bottom: 4px; }
.anchor-stat-main { font-size: 12px; font-weight: 700; color: #333; }
.anchor-stat-main.gold { color: #d97706; }
.anchor-stat-sub { font-size: 11px; color: #999; margin-top: 2px; }
.anchor-highlight { background: #f8f8f8; border-radius: 12px; padding: 10px 14px; margin-bottom: 12px; }
.anchor-highlight-title { font-size: 13px; font-weight: 700; color: #333; display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
.anchor-highlight-count { font-size: 11px; color: #999; font-weight: 400; }
.anchor-highlight-content { font-size: 12px; color: #666; }
.anchor-action-row { display: flex; justify-content: space-around; margin-bottom: 14px; }
.anchor-action-btn { display: flex; flex-direction: column; align-items: center; gap: 6px; font-size: 12px; color: #555; cursor: pointer; }
.anchor-action-icon { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22px; }
.gift-icon    { background: #ff9500; }
.profile-icon { background: #34aadc; }
.follow-icon  { background: #ff3b7f; }
.anchor-challenge-bar {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  background: linear-gradient(135deg,#fff0f6,#ffe4f0);
  border: 1.5px solid rgba(255,107,157,.35); border-radius: 24px;
  padding: 11px 20px; cursor: pointer; transition: background .2s;
}
.anchor-challenge-bar:active { background: linear-gradient(135deg,#ffe4f0,#ffd0e8); }
.anchor-challenge-icon { font-size: 16px; }
.anchor-challenge-text { font-size: 14px; font-weight: 700; color: #e8336d; }
.anchor-challenge-arrow { font-size: 14px; color: #e8336d; font-weight: 700; margin-left: 2px; }

/* ══════════════════════════════════
   演示按钮
══════════════════════════════════ */
.demo-trigger {
  position: absolute; bottom: 90px; left: 50%; transform: translateX(-50%);
  background: rgba(255,107,157,.9); color: #fff; border: none; border-radius: 20px;
  padding: 8px 20px; font-size: 13px; font-weight: 700;
  cursor: pointer; z-index: 15;
  box-shadow: 0 4px 16px rgba(255,107,157,.5); white-space: nowrap;
}

/* ══════════════════════════════════
   频道关系入口页（Screen 2）
══════════════════════════════════ */
/* 首页背景 */
.home-bg {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, #0d0018 0%, #06000f 100%);
  z-index: 0;
}
/* 首页顶部导航 */
.home-nav {
  position: absolute; top: 0; left: 0; right: 0; height: 88px;
  z-index: 10; padding: 44px 16px 0;
  display: flex; align-items: center; gap: 0;
}
.home-nav-tabs { display: flex; gap: 20px; flex: 1; justify-content: center; }
.home-nav-tab { font-size: 15px; color: rgba(255,255,255,.45); font-weight: 500; padding-bottom: 2px; }
.home-nav-tab.active { color: #fff; font-weight: 700; border-bottom: 2px solid #ff6b9d; }
.home-search { color: rgba(255,255,255,.6); font-size: 20px; }
.home-msg { color: rgba(255,255,255,.6); font-size: 20px; position: relative; }
.home-msg-dot {
  position: absolute; top: 0; right: 0;
  width: 7px; height: 7px; border-radius: 50%; background: #ff3b30;
}

/* 频道关系入口卡片 */
.channel-entry-wrap {
  position: absolute; top: 100px; left: 12px; right: 12px;
  z-index: 5;
}
.channel-entry-card {
  background: linear-gradient(135deg, rgba(255,107,157,.15), rgba(180,100,255,.1));
  border: 1px solid rgba(255,107,157,.3);
  border-radius: 16px; padding: 12px 14px;
  display: flex; align-items: center; gap: 12px;
  cursor: pointer; position: relative; overflow: hidden;
}
.channel-entry-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(255,107,157,.05), transparent);
  pointer-events: none;
}
.channel-entry-avatars {
  display: flex; align-items: center;
}
.channel-entry-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  border: 2px solid rgba(255,255,255,.3);
  overflow: hidden; background: #2a1040;
  margin-left: -8px;
}
.channel-entry-avatar:first-child { margin-left: 0; }
.channel-entry-avatar img { width:100%; height:100%; object-fit:cover; }
.channel-entry-info { flex: 1; }
.channel-entry-title { color: #fff; font-size: 13px; font-weight: 700; }
.channel-entry-sub { color: rgba(255,255,255,.5); font-size: 11px; margin-top: 2px; }
.channel-entry-badge {
  background: linear-gradient(135deg,#ff6b9d,#c96bff);
  color: #fff; font-size: 10px; font-weight: 700;
  padding: 3px 8px; border-radius: 10px; white-space: nowrap;
}

/* 悬浮提示入口（右下角） */
.float-entry {
  position: absolute; right: 12px; bottom: 72px;
  z-index: 20; cursor: pointer;
}
.float-entry-card {
  background: linear-gradient(135deg,#ff6b9d,#c96bff);
  border-radius: 28px; padding: 8px 14px 8px 10px;
  display: flex; align-items: center; gap: 8px;
  box-shadow: 0 4px 20px rgba(255,107,157,.5);
  animation: floatPulse 2s ease-in-out infinite;
}
@keyframes floatPulse {
  0%,100% { transform: scale(1); box-shadow: 0 4px 20px rgba(255,107,157,.5); }
  50% { transform: scale(1.04); box-shadow: 0 6px 28px rgba(255,107,157,.7); }
}
.float-entry-avatar {
  width: 32px; height: 32px; border-radius: 50%;
  border: 2px solid rgba(255,255,255,.5);
  overflow: hidden; background: #4a2060;
}
.float-entry-avatar img { width:100%; height:100%; object-fit:cover; }
.float-entry-text { display: flex; flex-direction: column; }
.float-entry-main { color: #fff; font-size: 12px; font-weight: 700; }
.float-entry-sub { color: rgba(255,255,255,.8); font-size: 10px; }
.float-entry-close {
  position: absolute; top: -6px; right: -6px;
  width: 18px; height: 18px; border-radius: 50%;
  background: rgba(0,0,0,.5); border: 1px solid rgba(255,255,255,.2);
  color: rgba(255,255,255,.7); font-size: 10px;
  display: flex; align-items: center; justify-content: center;
}

/* 首页房间列表 */
.home-room-list {
  position: absolute; top: 170px; left: 0; right: 0; bottom: 60px;
  overflow-y: auto; padding: 0 12px; z-index: 5;
}
.home-section-title {
  font-size: 13px; font-weight: 700; color: rgba(255,255,255,.6);
  margin: 12px 0 8px;
}
.home-room-row { display: flex; gap: 10px; margin-bottom: 10px; }
.home-room-card {
  flex: 1; border-radius: 14px; overflow: hidden;
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.08);
  cursor: pointer;
}
.home-room-thumb {
  height: 80px; background: linear-gradient(135deg, #2a0a3e, #1a0520);
  display: flex; align-items: center; justify-content: center;
  font-size: 32px; position: relative;
}
.home-room-live {
  position: absolute; top: 6px; left: 6px;
  background: #ff3b30; color: #fff; font-size: 9px; font-weight: 700;
  padding: 1px 5px; border-radius: 4px;
}
.home-room-info { padding: 6px 8px; }
.home-room-name { color: #fff; font-size: 11px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.home-room-meta { color: rgba(255,255,255,.35); font-size: 10px; margin-top: 2px; }

/* 首页底部导航 */
.home-bottom-nav {
  position: absolute; bottom: 0; left: 0; right: 0; height: 60px;
  background: rgba(10,0,15,.95); border-top: 1px solid rgba(255,255,255,.07);
  display: flex; align-items: center; justify-content: space-around;
  z-index: 10; padding-bottom: 4px;
}
.home-nav-btn { display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: pointer; }
.home-nav-btn-icon { font-size: 22px; }
.home-nav-btn-label { font-size: 10px; color: rgba(255,255,255,.4); }
.home-nav-btn.active .home-nav-btn-label { color: #ff9de2; }

/* 进入提示弹窗（进房后悬浮提示） */
.room-entry-toast {
  position: absolute; top: 96px; left: 12px; right: 12px;
  background: rgba(20,5,30,.92);
  border: 1px solid rgba(255,107,157,.4);
  border-radius: 14px; padding: 12px 14px;
  z-index: 25; display: none;
  animation: slideDown .4s ease-out;
}
.room-entry-toast.show { display: block; }
@keyframes slideDown {
  from { transform: translateY(-12px); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}
.toast-close {
  position: absolute; top: 8px; right: 10px;
  background: none; border: none; color: rgba(255,255,255,.35);
  font-size: 14px; cursor: pointer;
}
.toast-title { color: #ff9de2; font-size: 13px; font-weight: 700; margin-bottom: 4px; }
.toast-body { color: rgba(255,255,255,.65); font-size: 12px; line-height: 1.5; }
.toast-body em { color: #ffd700; font-style: normal; font-weight: 700; }
.toast-btn {
  margin-top: 8px; width: 100%; height: 34px;
  background: linear-gradient(135deg,#ff6b9d,#c96bff);
  border: none; border-radius: 17px;
  color: #fff; font-size: 13px; font-weight: 700; cursor: pointer;
}

/* ════════════════════════════════
   Screen 7: 主播中心看板
════════════════════════════════ */
.anchor-board-item {
  display: flex; align-items: center; gap: 12px;
  background: rgba(255,255,255,.05); border-radius: 14px;
  padding: 12px 12px; margin-bottom: 8px;
  border: 1px solid rgba(255,255,255,.07);
  transition: background .15s;
}
.anchor-board-item:active { background: rgba(255,255,255,.09); }
.abi-avatar {
  width: 46px; height: 46px; border-radius: 50%;
  overflow: hidden; background: #2a1040; flex-shrink: 0;
  border: 2px solid rgba(255,107,157,.25);
}
.abi-avatar img { width:100%; height:100%; object-fit:cover; }
.abi-info { flex: 1; min-width: 0; }
.abi-name { color: #fff; font-size: 13px; font-weight: 700; margin-bottom: 5px; }
.abi-progress { display: flex; gap: 6px; flex-wrap: wrap; }
.abi-node {
  font-size: 10px; font-weight: 600;
  padding: 2px 7px; border-radius: 8px;
}
.abi-node.done { background: rgba(76,217,100,.15); color: #4cd964; }
.abi-node.pending { background: rgba(255,255,255,.08); color: rgba(255,255,255,.4); }
.abi-right { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; flex-shrink: 0; }
.abi-days { color: rgba(255,255,255,.4); font-size: 11px; }
.abi-status-tag {
  font-size: 10px; font-weight: 700;
  padding: 2px 8px; border-radius: 8px; white-space: nowrap;
}
.status-ongoing { background: rgba(255,107,157,.15); color: #ff9de2; }
.status-node1 { background: rgba(90,160,255,.15); color: #80c8ff; }
.status-node2 { background: rgba(180,100,255,.15); color: #c96bff; }
.status-done-all { background: rgba(76,217,100,.15); color: #4cd964; }

/* s7 详情弹窗 */
.s7-detail-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,.55);
  z-index: 200; display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity .25s ease;
}
.s7-detail-overlay.show { opacity: 1; pointer-events: all; }
.s7-detail-card {
  width: 100%; background: #fff; border-radius: 20px 20px 0 0;
  padding: 20px 20px 32px; position: relative;
  transform: translateY(30px);
  transition: transform .3s cubic-bezier(.34,1.56,.64,1);
}
.s7-detail-overlay.show .s7-detail-card { transform: translateY(0); }
.s7-detail-close {
  position: absolute; top: 14px; right: 18px;
  background: none; border: none; color: #bbb;
  font-size: 18px; cursor: pointer;
}

/* s9 私信详情弹窗 */
.s9-msg-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,.55);
  z-index: 200; display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity .25s ease;
}
.s9-msg-overlay.show { opacity: 1; pointer-events: all; }
.s9-msg-card {
  width: 100%; background: #fff; border-radius: 20px 20px 0 0;
  padding-bottom: 32px; position: relative;
  transform: translateY(30px);
  transition: transform .3s cubic-bezier(.34,1.56,.64,1);
  max-height: 85%;
  overflow-y: auto;
}
.s9-msg-overlay.show .s9-msg-card { transform: translateY(0); }

/* ════════════════════════════════
   Screen 3: 心动挑战开启弹窗（独立展示）
════════════════════════════════ */
/* ══════════════════════════════════
   Screen 4: 心动挑战即将完成弹窗（独立展示）
══════════════════════════════════ */
/* ══════════════════════════════════
   Screen 5: 心动挑战详情页（独立展示）
══════════════════════════════════ */
/* ══════════════════════════════════
   Screen 6: 主播信息弹框（独立展示）
══════════════════════════════════ */

</style>
</head>
<body>

<!-- ══════════════════════════════════
     侧边目录导航
══════════════════════════════════ -->
<nav class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-title">💕 心动挑战 · 原型</div>
    <div class="sidebar-subtitle">PRD v1.3 · 交互原型图</div>
  </div>

  <div class="sidebar-section-label">用户视角</div>

  <div class="nav-item active" onclick="switchScreen('s1')" id="nav-s1">
    <div class="nav-dot pink"></div>
    <div class="nav-item-text">
      <div class="nav-item-name">语音房主界面</div>
      <div class="nav-item-sub">基础场景 · 入口触发</div>
    </div>
  </div>

  <div class="nav-item" onclick="switchScreen('s2')" id="nav-s2">
    <div class="nav-dot blue"></div>
    <div class="nav-item-text">
      <div class="nav-item-name">频道关系入口</div>
      <div class="nav-item-sub">首页悬浮提示入口</div>
    </div>
    <span class="nav-badge">NEW</span>
  </div>

  <div class="nav-item" onclick="switchScreen('s3')" id="nav-s3">
    <div class="nav-dot pink"></div>
    <div class="nav-item-text">
      <div class="nav-item-name">心动挑战开启弹窗</div>
      <div class="nav-item-sub">破除萌新身份后触发</div>
    </div>
  </div>

  <div class="nav-item" onclick="switchScreen('s4')" id="nav-s4">
    <div class="nav-dot purple"></div>
    <div class="nav-item-text">
      <div class="nav-item-name">即将完成弹窗</div>
      <div class="nav-item-sub">送出CP礼物后触发</div>
    </div>
